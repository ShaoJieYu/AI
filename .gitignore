# ============================================================
# 项目根 .gitignore —— 适用于 Node / Java / Python 多技术栈
# ============================================================

# ---------- Node / 前端 ----------
**/node_modules/
**/node_modules/.cache/
**/.vite/
**/dist/
**/build/
**/.next/
**/.nuxt/
**/.parcel-cache/
**/.turbo/
**/coverage/
**/.eslintcache
**/.stylelintcache
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/package-lock.json.bak
**/yarn.lock.bak

# ---------- Java / Maven ----------
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear
**/hs_err_pid*
**/replay_pid*
**/.mvn/
**/mvnw
**/mvnw.cmd
**/dependency-reduced-pom.xml

# ---------- Python ----------
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.so
**/.Python
**/venv/
**/env/
**/.venv/
**/.env.local
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.tox/
**/.coverage
**/htmlcov/

# ---------- 日志 / 运行时文件 ----------
**/logs/
**/*.log
**/*.log.*
**/*.lck
**/pids/
**/*.pid
**/*.seed
**/*.pid.lock
**/nohup.out

# ---------- 操作系统 / 编辑器 ----------
**/.DS_Store
**/Thumbs.db
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*~

# ---------- 基础设施运行时数据 ----------
# Nacos Derby/raft 持久化数据
**/nacos/data/
**/nacos/logs/
# Redis 数据文件
**/redis/dump.rdb
**/redis/appendonly.aof
**/redis/*.dat
# Sentinel 日志
**/sentinel/

# ---------- 密钥 / 敏感信息 ----------
# 实际 .env 由各模块自带的 .env.example 替代；.env 留作本地不跟踪
**/.env
!**/.env.example
**/*.pem
**/*.key
**/secrets/
**/credentials/

# ---------- 项目特定 ----------
# Chroma 向量数据库持久化数据（可重新入库生成）
**/chroma_db/
# 教材 PDF（有版权，不提交）
**/data/textbooks/
# Redis 持久化快照文件（运行时生成）
dump.rdb
*.rdb
# 老归档目录（_archive/）
_archive/
# 根目录已废弃的 web-frontend/（已迁到 02-Frontend/）
/web-frontend/
# 工具自身配置
.claude/
.trae/

# ---------- 上传 / 临时文件 ----------
**/uploads/
**/tmp/
**/temp/
**/*.tmp
**/*.bak
**/*.swp

# ---------- 演示文稿（外部素材，不入库）----------
01-Documentation/PPT/
